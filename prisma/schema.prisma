generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  admin
  client
  consultant
}

enum ClientOrgStatus {
  active
  inactive
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum AccountStatus {
  active
  suspended
  deactivated
}

enum PublicationStatus {
  draft
  published
  unpublished
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_ADMIN_REVIEW
  NEEDS_CLARIFICATION
  SCOPE_APPROVED
  READY_FOR_MATCHING
  MATCHING_IN_PROGRESS
  SHORTLIST_READY
  ENGAGEMENT_CREATED
  CLOSED
  CANCELLED
}

enum ScopeStatus {
  NOT_STARTED
  AI_DRAFTED
  ADMIN_REVIEW
  ADMIN_APPROVED
  CLIENT_CHANGE_REQUESTED
  CLIENT_CONFIRMED
  REJECTED
}

enum ShortlistStatus {
  DRAFT
  ADMIN_REVIEW
  CLIENT_VISIBLE
  UPDATED
  CLOSED
}

enum InvitationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED_INTEREST
  DECLINED
  QUESTIONS_ASKED
  PROPOSAL_SUBMITTED
  EXPIRED
  WITHDRAWN
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  SELECTED
  REJECTED
}

enum EngagementStatus {
  PENDING_START
  IN_PROGRESS
  DELIVERABLE_SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  DISPUTED
  ACCEPTED
  CLOSED
  CANCELLED
}

enum DeliverableStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REVISION_REQUESTED
}

enum RevisionRequestStatus {
  OPEN
  ADDRESSED
  WITHDRAWN
}

// ─── Auth & People ──────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientContact     ClientContact?
  consultantProfile ConsultantProfile?
  eventLogs         EventLog[]
  legalAcceptances  LegalAcceptanceRecord[]
}

model ClientOrganization {
  id        String          @id @default(cuid())
  name      String
  status    ClientOrgStatus @default(active)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  contacts ClientContact[]
  projects Project[]
}

model ClientContact {
  id             String   @id @default(cuid())
  userId         String   @unique
  organizationId String
  name           String
  email          String
  createdAt      DateTime @default(now())

  user         User               @relation(fields: [userId], references: [id])
  organization ClientOrganization @relation(fields: [organizationId], references: [id])
}

model ConsultantProfile {
  id                String            @id @default(cuid())
  userId            String            @unique
  approvalStatus    ApprovalStatus    @default(pending)
  accountStatus     AccountStatus     @default(active)
  publicationStatus PublicationStatus @default(draft)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user             User                    @relation(fields: [userId], references: [id])
  restrictions     ConsultantRestriction[]
  shortlistEntries ShortlistCandidate[]
  invitations      ConsultantInvitation[]
  proposals        Proposal[]
  engagements      Engagement[]
}

model ConsultantRestriction {
  id           String    @id @default(cuid())
  consultantId String
  type         String
  notes        String?
  activeFrom   DateTime
  activeTo     DateTime?
  createdAt    DateTime  @default(now())

  consultant ConsultantProfile @relation(fields: [consultantId], references: [id])
}

// ─── Project Spine ──────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  clientId    String
  status      ProjectStatus @default(DRAFT)
  title       String
  description String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      ClientOrganization     @relation(fields: [clientId], references: [id])
  scope       Scope?
  shortlist   Shortlist?
  engagements Engagement[]
  invitations ConsultantInvitation[]
}

model Scope {
  id                 String      @id @default(cuid())
  projectId          String      @unique
  status             ScopeStatus @default(NOT_STARTED)
  deliverable        String
  acceptanceCriteria String
  assumptions        String
  exclusions         String
  dueDate            DateTime
  fee                Decimal     @db.Decimal(10, 2)
  effortCapHours     Int
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  project     Project      @relation(fields: [projectId], references: [id])
  engagements Engagement[]
}

model Shortlist {
  id        String          @id @default(cuid())
  projectId String          @unique
  status    ShortlistStatus @default(DRAFT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  project    Project              @relation(fields: [projectId], references: [id])
  candidates ShortlistCandidate[]
}

model ShortlistCandidate {
  id           String   @id @default(cuid())
  shortlistId  String
  consultantId String
  addedBy      String
  rationale    String?
  createdAt    DateTime @default(now())

  shortlist   Shortlist         @relation(fields: [shortlistId], references: [id])
  consultant  ConsultantProfile @relation(fields: [consultantId], references: [id])
  invitations ConsultantInvitation[]
}

model ConsultantInvitation {
  id                   String           @id @default(cuid())
  shortlistCandidateId String
  projectId            String
  consultantId         String
  status               InvitationStatus @default(DRAFT)
  sentAt               DateTime?
  expiresAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  shortlistCandidate ShortlistCandidate @relation(fields: [shortlistCandidateId], references: [id])
  project            Project            @relation(fields: [projectId], references: [id])
  consultant         ConsultantProfile  @relation(fields: [consultantId], references: [id])
  proposals          Proposal[]
}

model Proposal {
  id           String         @id @default(cuid())
  invitationId String
  consultantId String
  status       ProposalStatus @default(DRAFT)
  fitStatement String
  deviations   Json           @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  invitation  ConsultantInvitation @relation(fields: [invitationId], references: [id])
  consultant  ConsultantProfile    @relation(fields: [consultantId], references: [id])
  engagements Engagement[]
}

model Engagement {
  id           String           @id @default(cuid())
  projectId    String
  scopeId      String
  proposalId   String
  consultantId String
  clientId     String
  status       EngagementStatus @default(PENDING_START)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  project          Project                  @relation(fields: [projectId], references: [id])
  scope            Scope                    @relation(fields: [scopeId], references: [id])
  proposal         Proposal                 @relation(fields: [proposalId], references: [id])
  consultant       ConsultantProfile        @relation(fields: [consultantId], references: [id])
  deliverables     Deliverable[]
  revisionRequests RevisionRequest[]
  communications   EngagementCommunication[]
}

model Deliverable {
  id           String            @id @default(cuid())
  engagementId String
  status       DeliverableStatus @default(PENDING)
  submittedAt  DateTime?
  fileUrl      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  engagement       Engagement      @relation(fields: [engagementId], references: [id])
  revisionRequests RevisionRequest[]
}

model RevisionRequest {
  id           String                @id @default(cuid())
  engagementId String
  deliverableId String
  requestedBy  String
  reason       String
  status       RevisionRequestStatus @default(OPEN)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  engagement  Engagement  @relation(fields: [engagementId], references: [id])
  deliverable Deliverable @relation(fields: [deliverableId], references: [id])
}

model EngagementCommunication {
  id           String   @id @default(cuid())
  engagementId String
  senderId     String
  senderRole   Role
  messageType  String
  body         String
  createdAt    DateTime @default(now())

  engagement Engagement @relation(fields: [engagementId], references: [id])

  @@index([engagementId])
}

// ─── Cross-cutting ──────────────────────────────────────────────────────────

model AIOutputLog {
  id            String   @id @default(cuid())
  touchpoint    String
  promptVersion String
  model         String
  inputSummary  String
  output        String
  exposed       Boolean  @default(false)
  reviewed      Boolean  @default(false)
  decision      String?
  timestamp     DateTime @default(now())
}

model EventLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  actorId    String
  actorRole  Role
  data       Json     @default("{}")
  timestamp  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model LegalAcceptanceRecord {
  id           String   @id @default(cuid())
  userId       String
  documentType String
  version      String
  acceptedAt   DateTime @default(now())
  ipAddress    String

  user User @relation(fields: [userId], references: [id])
}

// ─── Present in schema, empty in M1 ────────────────────────────────────────

model Dispute {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

model AdminTask {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

model ScopingMatrixClassification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}
